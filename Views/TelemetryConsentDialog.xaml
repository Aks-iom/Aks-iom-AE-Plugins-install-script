<Window x:Class="AEPluginInstaller.Views.TelemetryConsentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:AEPluginInstaller.Services.Localization"
        Title="Разрешение на телеметрию" Height="760" Width="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">
    
    <Border Background="{DynamicResource ChromeBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" MouseLeftButtonDown="DragWindow" Background="Transparent">
                <TextBlock Text="Улучшение приложения"
                           Foreground="{DynamicResource TextBrush}"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Margin="16,12"/>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0">
                <StackPanel Margin="24,10,24,20">
                    <Image Source="/Assets/logo.ico"
                           Width="64" Height="64"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                    <TextBlock Text="Помогите сделать установщик лучше!"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="18"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="Мы собираем анонимные отчеты об ошибках и успешных установках плагинов. Это помогает оперативно исправлять баги и улучшать работу программы."
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,0,0,12"/>

                    <TextBlock TextAlignment="Center" Margin="0,0,0,16">
                        <Hyperlink NavigateUri="https://telegra.ph/Telemetriya-AE-Plugins-Installer-05-27"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="{DynamicResource AccentBrush}"
                                   TextDecorations="None">
                            Подробнее о том, какие данные мы собираем
                        </Hyperlink>
                    </TextBlock>

                    <TextBlock Text="⚠️ Мы не собираем личные данные, списки ваших файлов или пароли."
                               Foreground="{DynamicResource SuccessBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="Даже если вы откажетесь, на сервер всё равно будет отправляться пустой файл (только имя со счётчиком успешных/неудачных установок и анонимным ID) — без содержимого журнала. Это нужно для общей статистики. Изменить выбор и посмотреть свой ID можно в Настройках."
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,0,0,18"/>

                    <CheckBox x:Name="CbConsent"
                              Content="Разрешить отправку анонимных отчётов с содержимым журнала"
                              IsChecked="True"
                              HorizontalAlignment="Center"
                              FontSize="13"
                              Margin="0,0,0,18"/>

                    <!-- Путь к After Effects -->
                    <Border Background="{DynamicResource BgBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,12"
                            Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="{loc:T Key=tcd.ae_path.title}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="{loc:T Key=tcd.ae_path.hint}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="AePathBox"
                                         Grid.Column="0"
                                         Padding="8,6"
                                         FontSize="12"
                                         VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="{loc:T Key=tcd.ae_path.browse}"
                                        Style="{DynamicResource GhostButton}"
                                        Padding="14,6"
                                        Margin="8,0,0,0"
                                        Click="BrowseAePath_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{DynamicResource BgBrush}" CornerRadius="0,0,10,10" Padding="16">
                <Button Content="Продолжить"
                        Style="{DynamicResource PrimaryButton}"
                        Click="Continue_Click"
                        HorizontalAlignment="Stretch"/>
            </Border>
        </Grid>
    </Border>
</Window>