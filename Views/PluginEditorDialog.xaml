<Window x:Class="AEPluginInstaller.Views.PluginEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:AEPluginInstaller.Services.Localization"
        Title="{loc:T Key=pluged.title}"
        Height="640" Width="720"
        MinHeight="480" MinWidth="600"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI"
        Icon="/Assets/logo.ico"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="24,20,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="{loc:T Key=pluged.title}"
                       FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="{loc:T Key=pluged.subtitle}"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Имя плагина -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="{loc:T Key=pluged.name}"
                       FontSize="11"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="NameBox"
                     FontSize="14" FontWeight="SemiBold"
                     Padding="10,7"/>
        </StackPanel>

        <!-- Список файлов: каждая карточка с вертикальной раскладкой полей -->
        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="14,12,14,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{loc:T Key=pluged.files_section}"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="FilesCountText"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Padding="8,0,8,8">
                    <ItemsControl x:Name="FilesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="6,5" Padding="12,10">
                                    <StackPanel>
                                        <!-- Шапка карточки файла: индекс + удалить -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding HeaderText}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource GhostButton}"
                                                    Content="{loc:T Key=pluged.remove_file}"
                                                    Padding="10,4"
                                                    FontSize="11"
                                                    Tag="{Binding}"
                                                    Click="RemoveFileBtn_Click"/>
                                        </Grid>

                                        <!-- URL -->
                                        <TextBlock Text="{loc:T Key=ed.col_url}"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Margin="0,0,0,2"/>
                                        <TextBox Text="{Binding GoogleDriveUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="8,5" Margin="0,0,0,8"/>

                                        <!-- Имя файла + Тип в одной строке -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{loc:T Key=ed.col_filename}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           Margin="0,0,0,2"/>
                                                <TextBox Text="{Binding FileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Padding="8,5"
                                                         ToolTip="{loc:T Key=ed.filename_hint}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{loc:T Key=ed.col_type}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           Margin="0,0,0,2"/>
                                                <ComboBox SelectedValuePath="Tag"
                                                          SelectedValue="{Binding Type, Mode=TwoWay}"
                                                          Padding="8,4">
                                                    <ComboBoxItem Content="{loc:T Key=ed.type.plugin}" Tag="Plugin"/>
                                                    <ComboBoxItem Content="{loc:T Key=ed.type.script}" Tag="Script"/>
                                                    <ComboBoxItem Content="{loc:T Key=ed.type.scriptui}" Tag="ScriptUI"/>
                                                    <ComboBoxItem Content="{loc:T Key=ed.type.archive}" Tag="Archive"/>
                                                    <ComboBoxItem Content="{loc:T Key=ed.type.installer}" Tag="Installer"/>
                                                    <ComboBoxItem Content="{loc:T Key=ed.type.reg}" Tag="RegFile"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Куда положить -->
                                        <TextBlock Text="{loc:T Key=ed.col_target}"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Margin="0,0,0,2"/>
                                        <TextBox Text="{Binding TargetPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="8,5"
                                                 ToolTip="{loc:T Key=ed.target_hint}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Подсказка по плейсхолдерам + добавить файл -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{loc:T Key=ed.target_hint}"
                       FontSize="10"
                       Foreground="{StaticResource TextMutedBrush}"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"/>
            <Button Grid.Column="1"
                    Style="{StaticResource GhostButton}"
                    Content="{loc:T Key=ed.add_file}"
                    Padding="14,7"
                    Click="AddFileBtn_Click"/>
        </Grid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{loc:T Key=dlg.cancel}"
                    Style="{StaticResource GhostButton}" Padding="20,8" Margin="0,0,8,0"
                    Click="CancelBtn_Click"/>
            <Button Content="{loc:T Key=ed.save}"
                    Style="{StaticResource PrimaryButton}" Padding="22,8"
                    Click="SaveBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
