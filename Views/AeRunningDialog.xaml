<Window x:Class="AEPluginInstaller.Views.AeRunningDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:AEPluginInstaller.Services.Localization"
        Title="{loc:T Key=dlg.ae_running.title}"
        SizeToContent="Height" Width="460"
        Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI" Icon="/Assets/logo.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="24,22,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="⚠" FontSize="22"
                       Foreground="{StaticResource AccentBrush}"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock Text="{loc:T Key=dlg.ae_running.title}"
                       FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
        <TextBlock Grid.Row="1" Text="{loc:T Key=dlg.ae_running.text}"
                   FontSize="13" Foreground="{StaticResource TextBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,18"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{loc:T Key=dlg.ae_running.skip}"
                    Style="{StaticResource GhostButton}" Padding="14,8" Margin="0,0,8,0"
                    Click="SkipBtn_Click"/>
            <Button Content="{loc:T Key=dlg.cancel}"
                    Style="{StaticResource GhostButton}" Padding="14,8" Margin="0,0,8,0"
                    Click="CancelBtn_Click"/>
            <Button Content="{loc:T Key=dlg.ae_running.continue}"
                    Style="{StaticResource PrimaryButton}" Padding="18,8"
                    Click="ContinueBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
