<UserControl x:Class="AEPluginInstaller.Views.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:AEPluginInstaller.Services.Localization"
             Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}"
             FontFamily="Segoe UI">
    <Grid Margin="24,22,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{loc:T Key=settings.title}"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Язык -->
                <TextBlock Text="{loc:T Key=settings.language}"
                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ComboBox x:Name="LangCombo" Width="220" HorizontalAlignment="Left"
                          Margin="0,0,0,6"/>
                <TextBlock x:Name="RestartHint" Text="{loc:T Key=settings.restart_hint}"
                           Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                           Visibility="Collapsed" Margin="0,0,0,18"/>
                <Border Margin="0,0,0,18" Height="0"/>

                <!-- Кэш -->
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="16" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{loc:T Key=settings.cache}"
                                   FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="CacheSizeText" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,4,0,10"/>
                        <Button Content="{loc:T Key=settings.cache.clear}"
                                Style="{StaticResource GhostButton}"
                                HorizontalAlignment="Left" Padding="14,7"
                                Click="ClearCacheBtn_Click"/>
                    </StackPanel>
                </Border>

                <!-- Телеметрия -->
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="16" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{loc:T Key=settings.telemetry}"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <TextBlock Text="{loc:T Key=settings.telemetry.user_id}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="UserIdBox"
                                     Grid.Column="0"
                                     IsReadOnly="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Padding="8,6"
                                     VerticalContentAlignment="Center"
                                     Background="{StaticResource BgBrush}"
                                     Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"/>
                            <Button Grid.Column="1"
                                    Content="{loc:T Key=settings.telemetry.copy}"
                                    Style="{StaticResource GhostButton}"
                                    Padding="14,6"
                                    Margin="8,0,0,0"
                                    Click="CopyUserIdBtn_Click"/>
                        </Grid>

                        <CheckBox x:Name="TelemetryCheck"
                                  Content="{loc:T Key=settings.telemetry.enabled}"
                                  FontSize="12"
                                  Margin="0,0,0,8"
                                  Click="TelemetryCheck_Click"/>

                        <TextBlock Text="{loc:T Key=settings.telemetry.note}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Пути к After Effects -->
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="16" Margin="0,0,0,14">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:T Key=settings.aepaths}"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="{loc:T Key=settings.aepaths.rescan}"
                                    Style="{StaticResource GhostButton}"
                                    Padding="12,6" FontSize="11"
                                    Click="RescanAePathsBtn_Click"/>
                        </Grid>
                        <TextBlock Text="{loc:T Key=settings.aepaths.hint}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>

                        <TextBlock x:Name="AePathsEmptyText"
                                   Text="{loc:T Key=settings.aepaths.empty}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"
                                   Margin="0,0,0,8"/>

                        <ItemsControl x:Name="AePathsItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6" Margin="0,3" Padding="10,8">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Background="{StaticResource ChromeBrush}"
                                                        CornerRadius="3" Padding="7,2"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding VersionLabel}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentBrush}"/>
                                                </Border>
                                                <Border Grid.Column="1"
                                                        Background="{StaticResource ChromeBrush}"
                                                        CornerRadius="3" Padding="7,2"
                                                        Margin="6,0,0,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding SourceLabel}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource TextMutedBrush}"/>
                                                </Border>
                                                <Button Grid.Column="3"
                                                        Content="{loc:T Key=settings.aepaths.remove}"
                                                        Style="{StaticResource GhostButton}"
                                                        Padding="10,4" FontSize="11"
                                                        Tag="{Binding}"
                                                        Visibility="{Binding CanRemove, Converter={StaticResource BoolToVis}}"
                                                        Click="RemoveAePathBtn_Click"/>
                                            </Grid>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         IsReadOnly="{Binding IsReadOnly}"
                                                         FontFamily="Consolas"
                                                         FontSize="11"
                                                         Padding="8,5"
                                                         VerticalContentAlignment="Center"/>
                                                <Button Grid.Column="1"
                                                        Content="{loc:T Key=settings.aepaths.browse}"
                                                        Style="{StaticResource GhostButton}"
                                                        Padding="10,5" FontSize="11"
                                                        Margin="6,0,0,0"
                                                        Tag="{Binding}"
                                                        Click="BrowseAePathBtn_Click"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="{loc:T Key=settings.aepaths.add}"
                                Style="{StaticResource GhostButton}"
                                Padding="14,7"
                                HorizontalAlignment="Left"
                                Margin="0,10,0,0"
                                Click="AddAePathBtn_Click"/>
                    </StackPanel>
                </Border>

                <!-- Чёрный список AE -->
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="{loc:T Key=settings.blacklist}"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock x:Name="BlacklistEmptyText"
                                   Text="{loc:T Key=settings.blacklist.empty}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>
                        <ItemsControl x:Name="BlacklistItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgBrush}"
                                            CornerRadius="6" Margin="0,3" Padding="10,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="1"
                                                    Content="{loc:T Key=settings.blacklist.remove}"
                                                    Style="{StaticResource GhostButton}"
                                                    Padding="10,4" FontSize="11"
                                                    Tag="{Binding}"
                                                    Click="RestoreBtn_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>