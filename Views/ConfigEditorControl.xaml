<UserControl x:Class="AEPluginInstaller.Views.ConfigEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:AEPluginInstaller.Services.Localization"
             Background="{StaticResource BgBrush}"
             Foreground="{StaticResource TextBrush}"
             FontFamily="Segoe UI">

    <Grid Margin="22,20,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{loc:T Key=ed.title}"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,14"/>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{loc:T Key=ed.name}" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox" Padding="10,7"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="{loc:T Key=ed.desc}" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="DescBox" Padding="10,7"/>
            </StackPanel>
        </Grid>

        <!-- Список плагинов: каждый — компактная карточка с кнопкой «Редактировать» -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="PluginsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="8" Margin="0,0,0,8" Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Имя + сводка -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Border Background="{StaticResource ChromeBrush}"
                                                CornerRadius="3" Padding="7,2"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TypeSummary}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentBrush}"/>
                                        </Border>
                                        <TextBlock Text="{Binding FilesCountText}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Style="{StaticResource GhostButton}"
                                        Content="{loc:T Key=ed.edit_plugin}"
                                        Padding="14,6"
                                        Margin="10,0,8,0"
                                        Tag="{Binding}"
                                        Click="EditPluginBtn_Click"/>

                                <Button Grid.Column="2"
                                        Style="{StaticResource GhostButton}"
                                        Content="{loc:T Key=ed.delete}"
                                        Padding="12,6"
                                        Tag="{Binding}"
                                        Click="RemovePluginBtn_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Style="{StaticResource GhostButton}"
                    Content="{loc:T Key=ed.add_plugin}"
                    Padding="14,7"
                    Click="AddPluginBtn_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Style="{StaticResource GhostButton}"
                    Content="{loc:T Key=dlg.cancel}" Padding="20,8"
                    Click="CancelBtn_Click"/>
            <Button Style="{StaticResource PrimaryButton}"
                    Content="{loc:T Key=ed.save}" Padding="22,8" Margin="8,0,0,0"
                    Click="SaveBtn_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
