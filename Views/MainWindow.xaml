<Window x:Class="AEPluginInstaller.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:AEPluginInstaller.Services.Localization"
        Title="AE Plugin Installer"
        Height="760" Width="1200"
        MinHeight="600" MinWidth="980"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI"
        Icon="/Assets/logo.ico"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Key="A" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.SelectAll}"/>
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Find}"/>
        <KeyBinding Key="I" Modifiers="Ctrl" Command="{x:Static MediaCommands.Play}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Save}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.SaveAs}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Open}"/>
        <KeyBinding Key="OemComma" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Properties}"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.SelectAll}" Executed="Hotkey_SelectAll"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Find}" Executed="Hotkey_Find"/>
        <CommandBinding Command="{x:Static MediaCommands.Play}" Executed="Hotkey_Install"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Save}" Executed="Hotkey_SaveLog"/>
        <CommandBinding Command="{x:Static ApplicationCommands.SaveAs}" Executed="Hotkey_ExportConfig"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Open}" Executed="Hotkey_ImportConfig"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Properties}" Executed="Hotkey_Settings"/>
    </Window.CommandBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>     <!-- шапка с версиями AE -->
            <RowDefinition Height="*"/>        <!-- два больших столбца -->
            <RowDefinition Height="Auto"/>     <!-- статус + прогресс + кнопки -->
            <RowDefinition Height="Auto"/>     <!-- футер -->
        </Grid.RowDefinitions>

        <!-- ============== ШАПКА: версии AE + конфиги ============== -->
        <Border Grid.Row="0"
                Background="{StaticResource ChromeBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,18,24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Слева: лого + заголовок + версии AE -->
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Image Source="/Assets/logo.ico" Width="28" Height="28"
                               VerticalAlignment="Center" Margin="0,0,12,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="{loc:T Key=app.brand}" FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{loc:T Key=app.subtitle}" FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"
                                   Margin="14,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{loc:T Key=header.ae_version}" FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ItemsControl x:Name="AeVersionPills">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton Style="{StaticResource PillRadio}"
                                                 GroupName="AeVersion"
                                                 Content="{Binding Version}"
                                                 Tag="{Binding}"
                                                 IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                 MouseRightButtonUp="AePill_RightClick"
                                                 Margin="0,0,6,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>

                <!-- Справа: выбор конфига -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{loc:T Key=header.config}" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox x:Name="ConfigsCombo" Width="220" Height="34"
                                  SelectionChanged="ConfigsCombo_SelectionChanged"
                                  DisplayMemberPath="Name"/>
                        <Button x:Name="AdvancedBtn" Style="{StaticResource GhostButton}"
                                Content="⚙" FontSize="14" Margin="6,0,0,0" Padding="14,6"
                                ToolTip="Дополнительно"
                                Click="AdvancedBtn_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============== ОСНОВНАЯ ОБЛАСТЬ: два столбца ============== -->
        <Grid Grid.Row="1" Margin="24,18,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="380"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*" MinWidth="380"/>
            </Grid.ColumnDefinitions>

            <!-- =========== ЛЕВО: выбор плагинов =========== -->
            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <Grid Grid.Row="0" Margin="18,16,18,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{loc:T Key=plugins.title}"
                                   FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" x:Name="PluginsCountLabel"
                                   FontSize="12" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </Grid>

                    <!-- Панель управления: «Выбрать все» слева, поиск справа -->
                    <Grid Grid.Row="1" Margin="18,4,18,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Выбрать все -->
                        <Border Grid.Column="0"
                                Background="{StaticResource BgBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10" Padding="14,8"
                                VerticalAlignment="Stretch">
                            <CheckBox x:Name="SelectAllCheck"
                                      Content="{loc:T Key=plugins.select_all}"
                                      FontWeight="SemiBold"
                                      FontSize="13"
                                      VerticalAlignment="Center"
                                      Click="SelectAllCheck_Click"/>
                        </Border>

                        <!-- Поиск -->
                        <Border Grid.Column="2"
                                Background="{StaticResource BgBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Grid>
                                <TextBox x:Name="SearchBox"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="38,7,12,7"
                                         FontSize="13"
                                         TextChanged="SearchBox_TextChanged"/>
                                <TextBlock Text="🔍" Foreground="{StaticResource TextMutedBrush}"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Center" Margin="14,0,0,0"
                                           FontSize="13"/>
                                <TextBlock x:Name="SearchPlaceholder" Text="{loc:T Key=plugins.search_placeholder}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Center" Margin="40,0,0,0"
                                           FontSize="13"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Список плагинов -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  Margin="10,0,10,12">
                        <ItemsControl x:Name="PluginsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="rowBorder"
                                            Background="Transparent"
                                            CornerRadius="6"
                                            Margin="4,1" Padding="12,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Click="PluginCheck_Click"/>
                                            <StackPanel Grid.Column="1" Margin="12,0,8,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="15" FontWeight="Bold"
                                                               VerticalAlignment="Center"/>
                                                    <Border Background="{StaticResource ChromeBrush}"
                                                            CornerRadius="3" Padding="7,2"
                                                            Margin="10,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding HasVersion, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="{Binding VersionDisplay}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource AccentBrush}"/>
                                                    </Border>
                                                    <Border Background="{StaticResource ChromeBrush}"
                                                            CornerRadius="3" Padding="7,2"
                                                            Margin="6,0,0,0"
                                                            VerticalAlignment="Center"
                                                            BorderBrush="{StaticResource SuccessBrush}"
                                                            BorderThickness="1"
                                                            Visibility="{Binding InstalledBadgeVisible, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="✓ установлен"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource SuccessBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Subtitle}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           Margin="0,3,0,0"
                                                           Visibility="{Binding HasSubtitle, Converter={StaticResource BoolToVis}}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Size}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- =========== ПРАВО: журнал событий =========== -->
            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="18,16,18,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{loc:T Key=log.title}"
                                   FontSize="16" FontWeight="SemiBold"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="{loc:T Key=log.save}"
                                    Style="{StaticResource GhostButton}"
                                    Padding="10,4" FontSize="11" Margin="0,0,6,0"
                                    Click="SaveLogBtn_Click"/>
                            <Button Content="{loc:T Key=log.clear}"
                                    Style="{StaticResource GhostButton}"
                                    Padding="10,4" FontSize="11"
                                    Click="ClearLogBtn_Click"/>
                        </StackPanel>
                    </Grid>

                    <ScrollViewer Grid.Row="1" x:Name="LogScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="18,0,18,14">
                        <TextBlock x:Name="LogText"
                                   FontFamily="Cascadia Mono, Consolas"
                                   FontSize="11"
                                   Foreground="{StaticResource TextBrush}"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>

                    <TextBlock x:Name="LogEmptyHint"
                               Grid.Row="1"
                               Text="{loc:T Key=log.empty}"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontStyle="Italic"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Margin="0,8,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ============== ПРОГРЕСС + КНОПКА ============== -->
        <Grid Grid.Row="2" Margin="24,4,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Прогресс-бар с текстом поверх -->
            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,12,0">
                <Grid>
                    <ProgressBar x:Name="MainProgress"
                                 Value="0" Maximum="100"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"
                                 MinHeight="44"/>
                    <TextBlock x:Name="ProgressText" Text="{loc:T Key=progress.idle}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="13" FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <Button Grid.Column="1" x:Name="InstallAllBtn"
                    Style="{StaticResource PrimaryButton}"
                    Content="{loc:T Key=install.button}"
                    Padding="28,12" FontSize="13"
                    Click="InstallSelectedBtn_Click"/>
        </Grid>

        <!-- ============== ФУТЕР ============== -->
        <Border Grid.Row="3"
                Background="{StaticResource ChromeBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,10,24,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           Text="{loc:T Key=app.tagline}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="ConfigPathLink" Text="{loc:T Key=footer.configs_folder}"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="11" Cursor="Hand"
                               MouseLeftButtonUp="ConfigPathLink_Click"/>
                    <TextBlock Text="  •  " Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    <TextBlock x:Name="ConfigsCountLabel" Text=""
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
