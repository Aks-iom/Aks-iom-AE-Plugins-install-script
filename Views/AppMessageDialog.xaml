<Window x:Class="AEPluginInstaller.Views.AppMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AE Plugin Installer"
        SizeToContent="Height"
        Width="440"
        MinHeight="160"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI"
        Icon="/Assets/logo.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Grid Margin="24,22,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock x:Name="IconText" Text="" FontSize="22"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock x:Name="TitleText" Text="" FontSize="16" FontWeight="Bold"
                       VerticalAlignment="Center" TextWrapping="Wrap"/>
        </StackPanel>

        <TextBlock Grid.Row="1" x:Name="MessageText"
                   Text=""
                   FontSize="13"
                   Foreground="{StaticResource TextBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,18"/>

        <StackPanel Grid.Row="2" x:Name="ButtonsPanel"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"/>
    </Grid>
</Window>
