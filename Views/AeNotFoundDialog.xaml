<Window x:Class="AEPluginInstaller.Views.AeNotFoundDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:AEPluginInstaller.Services.Localization"
        Title="AE not found"
        Height="240" Width="460"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI"
        Icon="/Assets/logo.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="24,22,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="TitleText"
                       Text=""
                       FontSize="17" FontWeight="Bold"/>
            <TextBlock x:Name="SubtitleText"
                       Text=""
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="12" Margin="0,6,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Text="{loc:T Key=dlg.ae_not_found.hint}"
                   Foreground="{StaticResource TextMutedBrush}"
                   FontSize="12" TextWrapping="Wrap"
                   VerticalAlignment="Top"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{loc:T Key=dlg.cancel}"
                    Style="{StaticResource GhostButton}"
                    Padding="18,8" Margin="0,0,8,0"
                    Click="CancelBtn_Click"/>
            <Button Content="{loc:T Key=dlg.browse}"
                    Style="{StaticResource PrimaryButton}"
                    Padding="18,8"
                    Click="BrowseBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
