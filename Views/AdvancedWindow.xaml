<Window x:Class="AEPluginInstaller.Views.AdvancedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Дополнительно"
        Height="640" Width="980"
        MinHeight="480" MinWidth="720"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{StaticResource TextBrush}"
        Icon="/Assets/logo.ico"
        FontFamily="Segoe UI">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Навигация в сайдбаре -->
        <Style x:Key="NavRadioStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource PanelHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A9B6CFF"/> <!-- Полупрозрачный фиолетовый -->
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопки управления окном (свернуть / закрыть) -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource PanelHoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Внешняя рамка окна со скруглением — фирменный «чром» приложения -->
    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- кастомный title bar -->
                <RowDefinition Height="*"/>      <!-- тело: сайдбар + контент -->
            </Grid.RowDefinitions>

            <!-- ============== TITLE BAR ============== -->
            <Border Grid.Row="0"
                    Background="{StaticResource ChromeBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="10,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <Image Source="/Assets/logo.ico" Width="18" Height="18"
                               VerticalAlignment="Center" Margin="0,0,10,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="Дополнительно"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button x:Name="MinBtn" Style="{StaticResource CaptionButton}" Click="MinBtn_Click" ToolTip="Свернуть">
                            <Path Data="M 0 0 H 10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.2"/>
                        </Button>
                        <Button x:Name="CloseBtn" Style="{StaticResource CloseButton}" Click="CloseBtn_Click" ToolTip="Закрыть">
                            <Path Data="M 0 0 L 10 10 M 10 0 L 0 10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.2"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============== ТЕЛО ============== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0"
                        Background="{StaticResource ChromeBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,1,0"
                        CornerRadius="0,0,0,10"
                        Padding="12,20,12,20">
                    <StackPanel>
                        <TextBlock Text="Настройки" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="8,0,0,8" />
                        <RadioButton Content="Общие настройки" GroupName="Nav" Style="{StaticResource NavRadioStyle}" Click="NavSettings_Click" />

                        <TextBlock Text="Конфигурации" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="8,16,0,8" />
                        <RadioButton Content="Новый конфиг" GroupName="Nav" Style="{StaticResource NavRadioStyle}" Click="NavNewConfig_Click" />
                        <RadioButton x:Name="EditBtn" Content="Редактировать текущий" GroupName="Nav" Style="{StaticResource NavRadioStyle}" Click="NavEditConfig_Click" />
                        <RadioButton Content="Импорт / Экспорт" GroupName="Nav" Style="{StaticResource NavRadioStyle}" Click="NavImportExport_Click" />

                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Margin="4,12,4,12"/>
                        <Button x:Name="DeleteBtn" Content="Удалить текущий" Style="{StaticResource GhostButton}" Click="NavDeleteConfig_Click" Padding="10,8" Foreground="{StaticResource DangerBrush}" HorizontalContentAlignment="Left" />
                    </StackPanel>
                </Border>

                <!-- Main Content Area (Transparent — скругление нижнего угла даёт внешний Border) -->
                <Grid Grid.Column="1" Background="Transparent">
                    <ContentControl x:Name="Host" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
                    <TextBlock x:Name="PlaceholderText" Text="Выберите раздел слева" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" FontStyle="Italic"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
